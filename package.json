{
  "name": "g9-cmd",
  "version": "1.4.0",
  "description": "G9 kommandoreferens",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.g9.cmd",
    "productName": "G9 CMD",
    "files": [
      "g9cmd.html",
      "main.js",
      "preload.js",
      "prism-core.min.js",
      "prism-bash.min.js",
      "prism-powershell.min.js",
      "prism-okaidia.min.css"
    ],
    "win": {
      "target": [
        { "target": "nsis" },
        { "target": "portable" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12"
  }
}